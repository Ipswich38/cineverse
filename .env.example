# VissionLink environment variables — names only, never commit real values.
# Local dev: copy to .env.local. Production: set in Vercel (project "cineversestore").
# Every variable here is read somewhere in app/ or lib/; the app degrades
# gracefully without the optional ones (seed catalog, FAQ-only chat, no email).

# ── Supabase (shared project fhlkrenefobhshouuopc) — REQUIRED for live data ──
# Without these the storefront serves the built-in seed catalog (read-only demo).
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=        # server-only; bypasses RLS — never expose client-side
NEXT_PUBLIC_SUPABASE_ANON_KEY=    # not currently read by code; kept for parity with Vercel

# ── Admin access — REQUIRED in production ──
# Passcode for /admin, sent as Bearer token to /api/admin/*. No fallback:
# if unset, all admin access fails closed (app/api/admin/_auth.ts).
ADMIN_SECRET=

# ── PayMongo (live payments) — REQUIRED for checkout ──
PAYMONGO_SECRET_KEY=              # sk_live_… or sk_test_…
PAYMONGO_WEBHOOK_SECRET=          # whsk_… for signature verification
PAYMONGO_METHODS=                 # optional CSV override, e.g. gcash,paymaya,card,grab_pay

# ── Zoho mail (hello@vissionlink.com) — REQUIRED for order/contact emails ──
ZOHO_SMTP_USER=
ZOHO_SMTP_PASS=
ZOHO_SMTP_HOST=                   # default smtppro.zoho.com
ZOHO_SMTP_PORT=                   # default 465
ZOHO_IMAP_HOST=                   # imappro.zoho.com — admin Inbox mirror (paid Zoho + IMAP enabled)
ZOHO_IMAP_PORT=                   # default 993
CONTACT_TO=                       # where contact-form mail is delivered
MAIL_BCC=                         # CSV of owner emails BCC'd on order documents

# ── Chatbots (storefront ChatWidget + admin assistant) — optional ──
# With no key the chat falls back to the built-in keyword FAQ.
GROQ_API_KEY=
GROQ_MODEL=                       # default llama-3.3-70b-versatile
GEMINI_API_KEY=                   # alternative provider
GEMINI_MODEL=

# ── Vercel cron (payment + return reminders, vercel.json) — REQUIRED in production ──
CRON_SECRET=                      # Vercel sends Authorization: Bearer $CRON_SECRET

# ── "My orders" magic links + courier tracking links — REQUIRED ──
# HMAC key signing the passwordless order-history links (lib/order-link.ts)
# and the courier check-in links (lib/track-link.ts).
# Generate with: openssl rand -hex 32. Unset → both features answer 503.
ORDER_LINK_SECRET=

# ── GPS hardware trackers (future) — optional ──
# Shared bearer token SIM trackers use to POST positions to /api/track.
# Leave unset until BMR installs devices; courier links work without it.
TRACK_DEVICE_TOKEN=
